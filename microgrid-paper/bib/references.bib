@article{zhang2024energy,
  author    = {David Dom{\'\i}nguez-Barbero and Javier Garc{\'\i}a-Gonz{\'a}lez and Miguel {\'A}. Sanz-Bobi and Aurelio Garc{\'\i}a-Cerrada},
  title     = {Energy management of a microgrid considering nonlinear losses in batteries through Deep Reinforcement Learning},
  journal   = {Applied Energy},
  volume    = {368},
  pages     = {123435},
  year      = {2024},
  doi       = {10.1016/j.apenergy.2024.123435},
  abstract  = {The massive deployment of microgrids could play a significant role in achieving decarbonization of the electric sector amid the ongoing energy transition. The effective operation of these microgrids requires an Energy Management System (EMS), which establishes control set-points for all dispatchable components. EMSs can be formulated as classical optimization problems or as Partially-Observable Markov Decision Processes (POMDPs). Recently, Deep Reinforcement Learning (DRL) algorithms have been employed to solve the latter, gaining popularity in recent years. Since DRL methods promise to deal effectively with nonlinear dynamics, this paper examines the Twin-Delayed Deep Deterministic Policy Gradient (TD3) performance – a state-of-the-art method in DRL – for the EMS of a microgrid that includes nonlinear battery losses. Furthermore, the classical EMS-microgrid interaction is improved by refining the behavior of the underlying control system to obtain reliable results. The performance of this novel approach has been tested on two distinct microgrids – a residential one and a larger-scale grid – with a satisfactory outcome beyond reducing operational costs. Findings demonstrate the intrinsic potential of DRL-based algorithms for enhancing energy management and driving more efficient power systems.}
}

@article{nakabi2023drl,
  author    = {Ying Ji and Jianhui Wang and Jiacan Xu and Xiaoke Fang and Huaguang Zhang},
  title     = {Real-Time Energy Management of a Microgrid Using Deep Reinforcement Learning},
  journal   = {Energies},
  volume    = {12},
  number    = {12},
  pages     = {2291},
  year      = {2019},
  doi       = {10.3390/en12122291},
  abstract  = {Driven by the recent advances and applications of smart-grid technologies, our electric power grid is undergoing radical modernization. Microgrid (MG) plays an important role in the course of modernization by providing a flexible way to integrate distributed renewable energy resources (RES) into the power grid. However, distributed RES, such as solar and wind, can be highly intermittent and stochastic. These uncertain resources combined with load demand result in random variations in both the supply and the demand sides, which make it difficult to effectively operate a MG. Focusing on this problem, this paper proposed a novel energy management approach for real-time scheduling of an MG considering the uncertainty of the load demand, renewable energy, and electricity price. Unlike the conventional model-based approaches requiring a predictor to estimate the uncertainty, the proposed solution is learning-based and does not require an explicit model of the uncertainty. Specifically, the MG energy management is modeled as a Markov Decision Process (MDP) with an objective of minimizing the daily operating cost. A deep reinforcement learning (DRL) approach is developed to solve the MDP. In the DRL approach, a deep feedforward neural network is designed to approximate the optimal action-value function, and the deep Q-network (DQN) algorithm is used to train the neural network. The proposed approach takes the state of the MG as inputs, and outputs directly the real-time generation schedules. Finally, using real power-grid data from the California Independent System Operator (CAISO), case studies are carried out to demonstrate the effectiveness of the proposed approach.}
}

@article{li2025battery,
  author    = {Vahid Safavi and Arash Mohammadi Vaniar and Najmeh Bazmohammadi and Juan C. Vasquez and Ozan Keysan and Josep M. Guerrero},
  title     = {A battery degradation-aware energy management system for agricultural microgrids},
  journal   = {Journal of Energy Storage},
  volume    = {108},
  pages     = {115059},
  year      = {2025},
  doi       = {10.1016/j.est.2024.115059},
  abstract  = {The integration of renewable energy sources (RESs) into power grids underscores the necessity for efficient energy storage solutions to ensure power balance and increase grid reliability. Although battery energy storage systems (BESSs) are pivotal for storing excess energy from RESs and mitigating peak demand periods, their chemical nature poses limitations, particularly in microgrid (MG) applications, due to degradation concerns that can lead to reduced performance over time. This necessitates careful consideration of degradation effects in optimizing system design and operation. This paper addresses this issue through developing a novel methodology aimed at optimizing the operation of renewable-based MGs while accounting for the degradation mechanisms of the battery storage systems. A machine learning model based on the XGBoost strategy is developed to predict the remaining useful life (RUL) of Lithium-ion (Li-ion) batteries, leveraging initial battery characteristics. This data-driven model is then incorporated into the day-ahead scheduling problem of an agricultural MG as a use-case to assess the impact of battery degradation modeling on the MG operation in both grid-connected and island operation modes. The proposed methodology utilizes the Coati Optimization Approach (COA) to determine optimal battery charging and discharging policy related to battery cycle limitations. The Monte Carlo Simulation (MCS) approach is employed to generate different scenarios reflecting varying power generation from RESs, electricity price volatility, and load demand variations. Case studies conducted on a real-world agricultural MG in Ankara, Turkey, demonstrate the effectiveness of the proposed methodology in reducing the total MG costs including both operational and degradation costs. Sensitivity analyses underscore the robustness of the methodology across various RES penetration levels and market conditions. Results reveal a reduction of 55.30% and 41.23% in the degradation cost of the agricultural MG in grid-connected and island modes, respectively, through the integration of the proposed data-driven-based battery degradation modeling.}
}

@article{kim2024optimized,
  author    = {M.I. Saleem and S. Saha and U. Izhar and L. Ang},
  title     = {Optimized energy management of a solar battery microgrid: An economic approach towards voltage stability},
  journal   = {Journal of Energy Storage},
  volume    = {90},
  part      = {B},
  pages     = {111876},
  year      = {2024},
  doi       = {10.1016/j.est.2024.111876},
  abstract  = {As the adoption of renewable energy sources (RESs) continues to surge, and the concept of microgrids (MGs) gains widespread recognition, the need for efficient battery energy storage system (BESS) management within MGs has become increasingly prominent. This paper introduces a novel Energy Management System (EMS) designed for grid-connected MGs, with the primary objectives of enhancing the energy economics of the MG, minimizing BESS degradation, and ensuring that the point of common coupling (PCC) voltage remains within prescribed limits. The proposed EMS utilizes a finite-horizon Model Predictive Control (MPC) framework to seamlessly coordinate BESS operations, encompassing charging, discharging, and reactive power provision. This coordination is done in conjunction with solar power generation, load demand, electricity pricing, and feed-in tariffs. Furthermore, the EMS accounts for uncertainties related to load and solar demand using a Monte Carlo simulation approach. The optimization goal of the proposed EMS is to minimize the expected total operational cost of the MG over a 24-hour prediction horizon. This cost encompasses both economic costs and battery degradation costs. The optimization process adheres to a set of constraints that consider BESS limitations, such as state of charge (SoC) constraints and charging/discharging limits, as well as inverter capacity limits and PCC voltage requirements. Conducting rigorous case studies on the MATLAB Simscape Electrical platform and validating them in real-time using the OPAL-RT simulator demonstrate the effectiveness of the proposed EMS across diverse operational scenarios and pricing models. The findings of these case studies provide valuable insights into the effectiveness of the EMS in real-world MG applications.}
}

@article{li2024energy,
  author  = {Yassine Ennassiri and Miguel de-Simón-Martín and Stefano Bracco and Michela Robba},
  title   = {Energy Management System for Polygeneration Microgrids, Including Battery Degradation and Curtailment Costs},
  journal = {Sensors},
  volume  = {24},
  number  = {22},
  pages   = {7122},
  year    = {2024},
  doi     = {10.3390/s24227122},
  abstract = {Recent advancements in sensor technologies have significantly improved the monitoring and control of various energy parameters, enabling more precise and adaptive management strategies for smart microgrids. This work presents a novel model of an energy management system (EMS) for grid-connected polygeneration microgrids that allows optimizing the management of electrical storage systems, electric vehicles, and other deferrable loads such as heat pumps. The main novelty of this model is that it incorporates both climate comfort variables and the consideration of the degradation of the energy storage capacity in the control strategy, as well as a penalty for the dumping of surpluses. The model has been applied to a smart, sustainable building as a case study. The results show that the proposed model is highly adaptable to diverse weather conditions, minimizing renewable energy losses while satisfying the energy demand and providing comfort to the building’s users. The study shows (i) that EVs’ dynamic charging schedules play a crucial role, (ii) that it is possible to minimize a battery’s degradation by optimizing its cycling, averaging one cycle per day, and (iii) the critical impact of seasonal weather patterns on microgrid energy management and the strategic role of EVs and storage systems in maintaining energy balance and efficiency.}
}

@article{greenbank2022impedance,
  author = {Samuel Greenbank and David A. Howey},
  title = {Impedance-based forecasting of lithium-ion battery performance amid uneven usage},
  journal = {Nature Communications},
  volume = {13},
  pages = {4806},
  year = {2022},
  doi = {10.1038/s41467-022-32422-w},
  abstract = {Accurate forecasting of lithium-ion battery performance is essential for easing consumer concerns about the safety and reliability of electric vehicles, but is challenging due to the complexity of battery degradation and the diversity of operating conditions and usage patterns. We introduce a method for predicting cell performance in real-world applications by using electrochemical impedance spectroscopy and probabilistic machine learning. A Gaussian process machine learning model is trained using impedance data collected at a single temperature and tabular features, easily obtained at the start of cycling, enabling capture of cell-to-cell variability. The method provides probabilistic forecasts of battery capacity and resistance trajectories amid uneven usage while quantifying forecast uncertainty. The accuracy of the method is demonstrated across different cathode chemistries and usage conditions, including a variable temperature scenario. This generalisable approach has potential to accelerate battery development and improve battery management.}
}

@article{barai2018study,
  author = {Anup Barai and Kotub Uddin and W. Dhammika Widanage and Andrew McGordon and Paul Jennings},
  title = {A study of the influence of measurement timescale on internal resistance characterisation methodologies for lithium-ion cells},
  journal = {Scientific Reports},
  volume = {8},
  number = {1},
  pages = {21},
  year = {2018},
  doi = {10.1038/s41598-017-18424-5},
  abstract = {The power capability of a lithium ion battery is governed by its resistance, which changes with battery state such as temperature, state of charge, and state of health. Characterising resistance is therefore important for system design and real-time management/control. Resistance characterisation methodologies are therefore required, but difficult to validate since true battery cell resistance is not clearly defined. This work critically reviews different AC and DC resistance methodologies, their objectives and their limits. We show that battery cell resistance assessed with Electrochemical Impedance Spectroscopy, although widely used, is not suitable for all applications. In addition, the relevance and benefits of DC techniques are demonstrated, even though these are often overlooked. The characteristics of a family of DC techniques are analysed in both time and frequency domains. In particular, the importance of the frequency content of the stimulus is demonstrated, showing that the wide variety of different resistance characterisation methodologies and objectives in the literature is due to differences in timescale of the processes they are sensitive to.}
}

@article{zhu2025joint,
  author = {Yongqiang Zhu and Xinhui Zhang and Weixiong Wu and Wenwei Wang},
  title = {Joint estimation of SOC and SOH for lithium-ion batteries based on FOAMIUHF-UKF model},
  journal = {Scientific Reports},
  volume = {15},
  pages = {40743},
  year = {2025},
  doi = {10.1038/s41598-025-24571-x},
  abstract = {Accurate state of charge (SOC) and state of health (SOH) estimation is critical for the battery management system (BMS) of lithium-ion batteries. To improve the accuracy of state estimation, a joint SOC and SOH estimation method proposed in the study based on a fractional-order model incorporates an adaptive multi-innovations unbiased hierarchical forgetting unscented Kalman filter (FOAMIUHF-UKF). Firstly, the fractional-order model of lithium-ion batteries is established. Secondly, the sparrow search algorithm (SSA) is used to identify the parameters of the fractional-order model. Finally, the FOAMIUHF-UKF algorithm is used to jointly estimate SOC and SOH. The proposed method is validated under dynamic stress test (DST) and highway driving schedule (HWY) conditions. The results show that the root mean square error (RMSE) of SOC estimation is less than 0.61%, and the mean absolute error (MAE) is less than 0.53%. The proposed method exhibits good robustness to initial SOC errors, temperature variations, and battery aging, with the maximum MAE of SOC estimation being less than 0.71%.}
}

@article{feng2023soc,
  author = {Fei Feng and Rengcun Fang and Xinfu Liu and Zhihao Liu and Jiapeng Wen and Ziang He and Zhenhua Lü and Yunlong Shang and Tao Peng},
  title = {A SOC Estimation Method for Li-Ion Batteries under High-Rate Pulse Conditions based on AO-BPNN Model},
  journal = {Space: Science \& Technology},
  volume = {3},
  pages = {0088},
  year = {2023},
  doi = {10.34133/space.0088},
  abstract = {State-of-charge (SOC) is a significant parameter of lithium-ion batteries for space power systems. Accurate SOC estimation can effectively ensure the safety and reliability of space missions. However, accurate SOC estimation under the high-rate pulse discharge conditions of space power systems is challenging. This study applies backpropagation neural network (BPNN) combined with Aquila optimizer (AO) algorithm to estimate SOC under high-rate pulse conditions, and the nonstatic data are used as the input of the model to avoid the depolarization phenomenon. The proposed model is trained and tested under the high-rate pulse conditions of 20, 30, and 40 C-rates, and the influences of the sampling interval and depolarization on the estimation accuracy of the model are discussed. The results show that the AO-BPNN model with nonstatic data has the best performance, with a mean absolute error of 6.16%, root mean square error of 7.77%, and coefficient of determination of 0.971, and the proposed model has the highest accuracy at 30 C-rate. The results also show that the sampling interval has a negligible effect on the estimation accuracy of the model, and the estimation accuracy of the model with nonstatic data is higher than that with static data by 2.3% on average.}
}

@article{rout2025estimation,
  author = {Sovan Rout and Satyabrata Sahoo and Deepak Mishra and Bidyadhar Subudhi and Anil Kumar Yadav},
  title = {Estimation of state of health for lithium-ion batteries using advanced data-driven techniques},
  journal = {Scientific Reports},
  volume = {15},
  pages = {30636},
  year = {2025},
  doi = {10.1038/s41598-025-93775-y},
  abstract = {This study proposes an advanced framework that leverages machine learning models to model the nonlinear degradation patterns of lithium-ion batteries by focusing on key indicators such as voltage, current, temperature, and internal resistance. The proposed method not only improves estimation accuracy but also reduces computational demands through optimized feature selection and model hyperparameter tuning. The effectiveness of the proposed method is evaluated using both laboratory data from the CALCE CS2 dataset and real-world data from the NASA dataset. The results demonstrate that the proposed method outperforms existing approaches, with a mean squared error (MSE) of 0.000115 and a coefficient of determination (R²) of 0.9982. This underscores the potential of the proposed method for precise and efficient battery health monitoring in practical applications.}
}

@article{ma2018temperature,
  author = {Qinghua Ma and Ping Bai and Jianbo Li and Shiming Wang and Guosheng Li},
  title = {Temperature effect and thermal impact in lithium-ion batteries: A review},
  journal = {Progress in Natural Science: Materials International},
  volume = {28},
  number = {6},
  pages = {653--666},
  year = {2018},
  doi = {10.1016/j.pnsc.2018.11.004},
  abstract = {Lithium-ion batteries, with high energy density (up to 705 Wh/L) and power density (up to 10,000 W/L) in an optimized cell design, exhibit high discharge capability (up to 6C-rate with 80% retention at the 500th cycle) at room temperature and low energy dissipation. However, their operation at extreme temperatures results in degradation of several processes and irreversible changes to the battery. In this review, we discuss the effects of temperature to lithium-ion batteries at both low and high temperature ranges. The current approaches in monitoring the thermal behavior of lithium-ion batteries are also reviewed. The thermal management systems of electric vehicles and hybrid electric vehicles are also discussed.}
}

@article{guo2022heat,
  author = {Jia Guo and Yaohua Mai},
  title = {Heat Generation and Degradation Mechanism of Lithium-Ion Battery during High-Temperature Aging},
  journal = {ACS Omega},
  volume = {7},
  number = {48},
  pages = {44122--44133},
  year = {2022},
  doi = {10.1021/acsomega.2c04093},
  abstract = {This work comprehensively investigates the evolution of heat generation characteristics upon discharging and electrochemical performance and the degradation mechanism of a commercial lithium-ion battery (LIB) during high-temperature aging. Post-mortem analysis is carried out to reveal the underlying mechanism of performance degradation, including X-ray diffraction (XRD), scanning electron microscopy (SEM), and transmission electron microscopy (TEM). The cell capacity plays a leading role, whose degradation makes the temperature rise decrease. With the aging deepening, the severe cell polarization makes the Joule heat proportion increase, causing a temperature rise increase. The solid electrolyte interface (SEI) film thickening and Li deposition on the anode electrode, the LiF generation from HF attacking on LiPF6, the electrolyte consumption, and the cathode electrolyte interface (CEI) film thickening on the cathode electrode are responsible for the capacity degradation. The SEI film thickening and decomposition, the electrolyte consumption, and the conductivity decrease of the electrolyte mainly account for the cell polarization.}
}

@article{hosen2024exploring,
  author = {Md Sazzad Hosen and Poonam Yadav and Joeri Van Mierlo and Maitane Berecibar},
  title = {Exploring Lithium-Ion Battery Degradation: A Concise Review of Critical Factors, Impacts, Data-Driven Degradation Estimation Techniques, and Sustainable Directions for Energy Storage Systems},
  journal = {Batteries},
  volume = {10},
  number = {7},
  pages = {220},
  year = {2024},
  doi = {10.3390/batteries10070220},
  abstract = {This paper presents a comprehensive review aimed at investigating the intricate phenomenon of battery degradation within the realm of sustainable energy storage systems. The escalating demand for reliable and environmentally friendly energy storage solutions necessitates a profound understanding of the factors influencing the lifespan and performance of lithium-ion batteries. This review consolidates current knowledge on the diverse array of factors influencing battery degradation mechanisms, encompassing thermal stresses, cycling patterns, electrode materials, and environmental conditions. Furthermore, it delves into the intricate interplay between these factors, providing a nuanced perspective on their synergistic effects. This review also offers a detailed exploration of various data-driven degradation estimation techniques, highlighting their strengths and limitations in capturing the dynamic nature of battery degradation. Finally, the paper proposes sustainable directions for future research and development in energy storage systems, emphasizing the importance of mitigating degradation factors to enhance battery durability and overall system sustainability. This holistic examination contributes valuable insights to the ongoing discourse on optimizing lithium-ion battery performance for a more sustainable energy future.}
}

